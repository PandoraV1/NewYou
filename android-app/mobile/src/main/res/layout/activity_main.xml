<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0F0">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New You"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for Watch..."
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/durationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#666666"
                android:visibility="gone" />

            <TextView
                android:id="@+id/readyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- STAT BOX: Overall Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Overall Summary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statTotalWorkouts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total Workouts: --"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                    <TextView
                        android:id="@+id/statWeeksTracked"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Weeks Tracked: --"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                    <TextView
                        android:id="@+id/statAvgWorkoutsPerWeek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Avg Workouts/Week: --"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Heart Rate -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❤️ Average Heart Rate"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statAvgHROverall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Overall Avg: -- bpm"
                        android:textSize="18sp"
                        android:textColor="#E53935"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statHRByActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Calories -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔥 Calories Burned"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statAvgCaloriesOverall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Avg Per Session: -- kcal"
                        android:textSize="18sp"
                        android:textColor="#FF6F00"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statCaloriesByActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Time -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱️ Time Active"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statAvgTimePerSession"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Avg Session: --"
                        android:textSize="18sp"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/statAvgTimePerWeek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Avg Per Week: --"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statTimeByActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Running -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏃 Running"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statRunning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Swimming -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏊 Swimming"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statSwimming"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Biking -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚴 Biking"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statBiking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Walking -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚶 Walking"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statWalking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Hiking -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🥾 Hiking"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statHiking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Meditation -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🧘 Meditation"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statMeditation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Strength Training -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏋️ Strength Training"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statStrength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT BOX: Yoga -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🧘 Yoga"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/statYoga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No sessions yet"
                        android:textSize="13sp"
                        android:textColor="#555555" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Nav bar at bottom -->
    <include layout="@layout/nav_bar" />

</LinearLayout>